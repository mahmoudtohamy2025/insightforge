# InsightForge — environment template.
# Copy to `.env` for local dev and set the values. `.env` is gitignored — never commit real values.
# In production, set these in the Vercel project's Environment Variables.
#
# NOTE: every VITE_* var is bundled into the client JS and shipped to the browser.
# Only ever put PUBLIC values here (Supabase anon/publishable key, PostHog project key).
# NEVER put server secrets (service_role key, Stripe secret key, etc.) in a VITE_* var.

# --- Supabase (required) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
# Anon/publishable key (role: anon) — public by design, protected by RLS.
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- PostHog product analytics (optional — app no-ops if unset) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# --- Sentry error tracking (optional — app no-ops if VITE_SENTRY_DSN unset) ---
VITE_SENTRY_DSN=
# Optional override for the Sentry environment tag (defaults to Vite's MODE).
VITE_SENTRY_ENV=

# --- Auto-injected by Vercel at build time — do NOT set manually ---
# VITE_VERCEL_GIT_COMMIT_SHA   (used as the Sentry release tag)
