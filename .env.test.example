# InsightForge — E2E test environment TEMPLATE (committed).
# Copy to `.env.test` (gitignored) and fill VITE_SUPABASE_PUBLISHABLE_KEY from
# `supabase status` after `supabase start`. See e2e/README.md for the full flow.
#
# Loaded by `vite --mode test` (the `dev:test` script), which Playwright's
# webServer boots. Points the app at the LOCAL `supabase start` stack so the
# Playwright specs sign up throwaway users locally and NEVER touch prod.
#
# The local API URL (54321) and the local publishable key are non-secret —
# they only authorize the local stack — but the key is generated per machine,
# which is why .env.test itself is gitignored rather than committed.

# --- Local Supabase (from `supabase status`) ---
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PROJECT_ID=local
# Paste the "Publishable" key printed by `supabase status` (starts with sb_publishable_):
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Analytics/error-tracking OFF in tests (override the values in .env) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
VITE_SENTRY_DSN=
